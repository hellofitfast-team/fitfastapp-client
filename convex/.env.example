# OpenRouter AI (for meal/workout plan generation and OCR)
OPENROUTER_API_KEY=

# Resend (transactional emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=FitFast <noreply@fitfast.app>

# Web Push (VAPID keys — generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@fitfast.app

# Client app URL (used in emails for links back to the app)
CLIENT_APP_URL=https://app.fitfast.app

# Marketing site URL (used for CORS in HTTP endpoints)
MARKETING_SITE_URL=

# Seed data (only needed for development)
SEED_USER_PASSWORD=
